{
  "name": "@d-id/node-sdk",
  "private": false,
  "version": "1.9.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/de-id/node-sdk"
  },
  "description": "D-ID Node SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint --ignore-path .gitignore . --ext ts",
    "build:docs": "typedoc",
    "generate:lib": "openapi-generator generate -i ${npm_config_openapi-spec} -g typescript-axios --additional-properties=stringEnums=true,supportsES6=true,withNodeImports=true,apiPackage=api,modelPackage=models,withSeparateModelsAndApi=true -o ${npm_config_lib-dir}"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "tslib": "^2.3.0",
    "ws": "^8.15.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^11.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^11.0.1",
    "@semantic-release/release-notes-generator": "^12.1.0",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "eslint": "~8.46.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^8.0.3",
    "prettier": "^2.8.8",
    "semantic-release": "^22.0.8",
    "ts-node": "^10.9.1",
    "typedoc": "^0.25.4",
    "typedoc-plugin-markdown": "^3.17.1",
    "typedoc-plugin-merge-modules": "^5.1.0",
    "typedoc-plugin-rename-defaults": "^0.7.0",
    "typescript": "~5.2.2"
  },
  "files": [
    "dist/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "author": "D-ID",
  "license": "Apache-2.0"
}
